    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26",
    "@types/react": "^19.2.17",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "semantic-release": "^25.0.5",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "^22.0.0"
