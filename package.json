{
  "name": "kofc-next",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "node scripts/check-node-version.mjs && next build",
    "cypress:open": "cypress open",
    "db:migrate": "node scripts/check-node-version.mjs && npx tsx src/db/migrate.ts",
    "dev": "node scripts/check-node-version.mjs && next dev --hostname 0.0.0.0",
    "format": "biome format --write",
    "postinstall": "npm rebuild better-sqlite3 --foreground-scripts",
    "lint": "biome check",
    "member:seed-password": "node scripts/check-node-version.mjs && npx tsx scripts/seed-member-password.ts",
    "prepare": "husky",
    "rebuild:native": "npm rebuild better-sqlite3 --foreground-scripts",
    "start": "next start"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material-nextjs": "^9.1.1",
    "@types/leaflet": "^1.9.21",
    "@uidotdev/usehooks": "^2.4.1",
    "better-auth": "^1.6.20",
    "better-sqlite3": "^12.11.1",
    "csv-parse": "^7.0.0",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "ical-generator": "^11.0.0",
    "leaflet": "^1.9.4",
    "leaflet-defaulticon-compatibility": "^0.1.2",
    "mailgun.js": "^13.2.0",
    "next": "^16.2.9",
    "nominatim-browser": "^2.1.0",
    "react": "^19.2.7",
    "react-big-calendar": "^1.20.0",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@biomejs/biome": "^2.5.0",
    "@codedependant/semantic-release-docker": "^7.0.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@mui/material": "^9.1.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
